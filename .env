# OpenRouter API Key
OPENROUTER_API_KEY=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

# Use Arcee Trinity model (excellent for RAG)
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free

# Optional: Alternative models (commented)
# OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
# OPENROUTER_MODEL=google/gemma-3-12b-instruct:free

OPENROUTER_SITE_URL=http://localhost
OPENROUTER_SITE_NAME=MyRAGSystem

# Choose LLM provider
LLM_PROVIDER=openrouter

# Embedding model
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Chunking parameters
CHUNK_SIZE=512
CHUNK_OVERLAP=50
CHUNKING_STRATEGY=semantic

# Search parameters
TOP_K_RESULTS=5
USE_RERANKER=false